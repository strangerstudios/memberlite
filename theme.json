{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 4,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false
		},
		"custom": {
			"border": {
				"radius": "8px"
			},
			"lineHeight": {
				"body": 1.7,
				"heading": 1.4,
				"field": 1.5
			}
		},
		"layout": {
			"contentSize": "805px",
			"wideSize": "1230px"
		},
		"spacing": {
			"spacingScale": {
				"steps": 7
			},
			"spacingSizes": [
				{
					"size": "clamp(10px, 2vw, 20px)",
					"slug": "10",
					"name": "1"
				},
				{
					"size": "clamp(20px, 3vw, 30px)",
					"slug": "20",
					"name": "2"
				},
				{
					"size": "clamp(30px, 4vw, 40px)",
					"slug": "30",
					"name": "3 (Outer)"
				},
				{
					"size": "clamp(40px, 5vw, 50px)",
					"slug": "40",
					"name": "4"
				},
				{
					"size": "clamp(50px, 6vw, 60px)",
					"slug": "50",
					"name": "5"
				},
				{
					"size": "clamp(60px, 7vw, 70px)",
					"slug": "60",
					"name": "6"
				},
				{
					"size": "clamp(70px, 8vw, 80px)",
					"slug": "70",
					"name": "7"
				}
			],
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
