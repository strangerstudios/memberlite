								"bottom": "calc( var(--wp--preset--spacing--10) / 2)",
								"left": "var(--wp--preset--spacing--10)"
							}
						},
						":hover": {
							"color": {
								"background": "currentColor",
								"text": "var(--wp--preset--color--base)"
